{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2020",
        "sourceMap": true,
        "outDir": ".medusa/server",
        "baseUrl": ".",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": false,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    },
    "include": [
        "src",
        "medusa-config.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        ".medusa"
    ]
}